# URL of your VoiceFlow AI backend (the Express API, not the voice-service)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Sentry error monitoring. Free tier at sentry.io. Leave blank to disable.
# Same DSN value in both - SENTRY_DSN for server/edge code, NEXT_PUBLIC_SENTRY_DSN so
# the browser bundle can see it too (Sentry DSNs aren't secret, they only allow
# *sending* events).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
